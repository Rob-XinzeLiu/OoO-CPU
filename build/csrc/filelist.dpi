DPI_STUB_OBJS_OBJ0=./../cpu.simv.daidir/vc_hdrs.o
DPI_STUB_OBJS_SRC0=./../cpu.simv.daidir/vc_hdrs.c
DPI_STUB_OBJS += $(DPI_STUB_OBJS_OBJ0)
$(DPI_STUB_OBJS_OBJ0): $(DPI_STUB_OBJS_SRC0)
	@$(CC) -I/usr/caen/vcs-2023.12-SP2-1/include  -pipe -fPIC    -I/usr/caen/vcs-2023.12-SP2-1/include  -fPIC -c -o $(DPI_STUB_OBJS_OBJ0) $(DPI_STUB_OBJS_SRC0)
	@strip -g $(DPI_STUB_OBJS_OBJ0)
